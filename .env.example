# ── Profound integration ─────────────────────────────────────────────────────
# Paste your real key into .env.local (gitignored). The War Room runs fully on
# demo data without these; with them, it pulls LIVE Profound data + can execute
# a Profound-native agent.

# REST API key (header: X-API-Key). https://api.tryprofound.com
PROFOUND_API_KEY=

# Optional: pin a specific category (else Bastion picks the first one).
PROFOUND_CATEGORY_ID=

# Optional: a registered Profound agent id to execute from the War Room.
PROFOUND_AGENT_ID=

# MCP endpoint (Streamable HTTP) for the Profound-native agent builder.
PROFOUND_MCP_ENDPOINT=https://mcp.tryprofound.com/mcp
